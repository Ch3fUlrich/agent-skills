# Environment variables for MCP servers
# Copy to .env and adjust as needed

# ─── Docker Compose ──────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=mcp-servers

# ─── Ollama ──────────────────────────────────────────────────────────────────
# Model to use for embeddings (pulled automatically on first start)
OLLAMA_MODEL=bge-m3
# GPU device index (0 = first GPU, -1 = CPU only)
OLLAMA_GPU=0

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=mem0_memories

# ─── Mem0 Configuration ─────────────────────────────────────────────────────
# Path to Mem0 config file (relative to this directory)
MEM0_CONFIG_PATH=config/mem0-config.yaml
