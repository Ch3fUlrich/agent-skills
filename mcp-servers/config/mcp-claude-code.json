{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from", "serena-agent",
        "serena",
        "start-mcp-server",
        "--project-from-cwd",
        "--open-web-dashboard", "false",
        "--enable-gui-log-window", "false"
      ],
      "env": {
        "SERENA_HOME": "C:/Users/mauls/.serena"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "mem0": {
      "type": "sse",
      "url": "http://localhost:8001/sse"
    },
    "superpowers": {
      "command": "node",
      "args": [
        "C:/Users/mauls/Documents/Code/agent-skills/mcp-servers/servers/superpowers/build/index.js"
      ]
    }
  }
}
