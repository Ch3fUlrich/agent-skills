{
  "servers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "serena-agent",
        "serena",
        "start-mcp-server",
        "--open-web-dashboard",
        "false",
        "--enable-gui-log-window",
        "false"
      ],
      "env": {
        "SERENA_HOME": "C:/Users/mauls/.serena"
      },
      "excludeTools": [
        "onboarding",
        "open_dashboard",
        "initial_instructions",
        "write_memory",
        "read_memory",
        "list_memories",
        "delete_memory",
        "rename_memory",
        "edit_memory"
      ],
      "connect_timeout": 120,
      "execute_timeout": 240,
      "disabled": false
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "connect_timeout": 60,
      "execute_timeout": 120,
      "disabled": false
    },
    "mem0": {
      "type": "sse",
      "url": "http://localhost:8001/sse",
      "excludeTools": [
        "health"
      ],
      "connect_timeout": 60,
      "execute_timeout": 120,
      "disabled": false
    },
    "superpowers": {
      "command": "node",
      "args": [
        "C:/Users/mauls/Documents/Code/agent-skills/mcp-servers/servers/superpowers/build/index.js"
      ],
      "connect_timeout": 60,
      "execute_timeout": 120,
      "disabled": false
    },
    "graphify": {
      "command": "uv",
      "args": [
        "--quiet",
        "run",
        "--with",
        "graphifyy[mcp]",
        "python",
        "-m",
        "graphify.serve",
        "graphify-out/graph.json"
      ],
      "connect_timeout": 120,
      "execute_timeout": 240,
      "disabled": false
    }
  }
}
