# Normalise text in the repo; decide line endings per type on checkout.
* text=auto

# Shell scripts MUST be LF everywhere. A CRLF shebang makes the kernel look for an
# interpreter literally named `bash\r` -> "bad interpreter: No such file or directory",
# so a Windows checkout (core.autocrlf=true) silently produces scripts that cannot run
# on Linux or via ./script. Same for the systemd units and the Python helpers they call.
*.sh            text eol=lf
*.py            text eol=lf
*.service       text eol=lf
*.timer         text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.pg            text eol=lf
*.gq            text eol=lf
*.jsonl         text eol=lf
Dockerfile      text eol=lf
.env.example    text eol=lf

# Extensionless shell wrappers meant for PATH (e.g. the graphify-mcp server wrapper) —
# same CRLF-shebang hazard as *.sh, but no extension to match on.
infra/mcp-servers/bin/* text eol=lf

# PowerShell is Windows-native; CRLF is correct there.
*.ps1           text eol=crlf
