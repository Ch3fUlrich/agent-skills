# General Settings
PUID=1000
PGID=1000
TZ=Europe/Berlin

# Paths (Keep C:/Apps approach as requested)
APPS_ROOT=C:/Apps
# Base workspace path for OpenHands on the workstation. Ensure this directory exists.
WORKSPACE_BASE=C:/Apps/coding_workspace

# Ports
OPENHANDS_PORT=3000
OPENWEBUI_HTTP_PORT=3131
OLLAMA_API_PORT=11434
LITELLM_PORT=4000

# Security (Required: Generate a strong key, e.g., openssl rand -hex 32)
WEBUI_SECRET_KEY=replace_with_a_secure_random_key_here

# OpenHands Sandbox
SANDBOX_RUNTIME_CONTAINER_IMAGE=ghcr.io/all-hands-ai/runtime:main

# API Keys for LiteLLM / General Proxy Use
LITELLM_MASTER_KEY=sk-proxy-1234
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# OpenHands Specific LLM settings (Optional)
# Leave LLM blank to configure in the OpenHands GUI, or point at 
# the local LiteLLM proxy (http://host.docker.internal:4000/v1) for unified key management.
OPENHANDS_LLM_MODEL=
OPENHANDS_LLM_BASE_URL=
OPENHANDS_LLM_API_KEY=

# Multi-provider API keys for OpenHands (placeholders — set your own; never commit real keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
