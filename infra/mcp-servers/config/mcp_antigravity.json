{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "serena-agent",
        "serena",
        "start-mcp-server",
        "--open-web-dashboard",
        "false",
        "--enable-gui-log-window",
        "false"
      ],
      "env": {
        "SERENA_HOME": "${SERENA_HOME}"
      },
      "excludeTools": [
        "onboarding",
        "open_dashboard",
        "initial_instructions",
        "write_memory",
        "read_memory",
        "list_memories",
        "delete_memory",
        "rename_memory",
        "edit_memory"
      ]
    },
    "omnigraph": {
      "command": "npx",
      "args": [
        "-y",
        "@modernrelay/omnigraph-mcp"
      ],
      "env": {
        "OMNIGRAPH_BASE_URL": "http://localhost:8080",
        "OMNIGRAPH_GRAPH_ID": "memory",
        "OMNIGRAPH_TOKEN": "${OMNIGRAPH_TOKEN}"
      }
    },
    "superpowers": {
      "command": "node",
      "args": [
        "${AGENT_SKILLS_DIR}/infra/mcp-servers/servers/superpowers/build/index.js"
      ]
    },
    "graphify": {
      "command": "uv",
      "args": [
        "--quiet",
        "run",
        "--with",
        "graphifyy[mcp]",
        "python",
        "-m",
        "graphify.serve",
        "${workspaceFolder}/graphify-out/graph.json"
      ]
    },
    "graphify-docker": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-v",
        "${workspaceFolder}:/repo",
        "graphify-mcp:latest"
      ]
    }
  }
}
