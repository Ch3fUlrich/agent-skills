{
  "servers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "serena-agent",
        "serena",
        "start-mcp-server",
        "--open-web-dashboard",
        "false",
        "--enable-gui-log-window",
        "false"
      ],
      "env": {
        "SERENA_HOME": "${SERENA_HOME}"
      },
      "excludeTools": [
        "onboarding",
        "open_dashboard",
        "initial_instructions",
        "write_memory",
        "read_memory",
        "list_memories",
        "delete_memory",
        "rename_memory",
        "edit_memory"
      ],
      "connect_timeout": 120,
      "execute_timeout": 240,
      "disabled": false
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "connect_timeout": 60,
      "execute_timeout": 120,
      "disabled": false
    },
    "omnigraph": {
      "command": "npx",
      "args": [
        "-y",
        "@modernrelay/omnigraph-mcp"
      ],
      "env": {
        "OMNIGRAPH_BASE_URL": "http://localhost:8080",
        "OMNIGRAPH_GRAPH_ID": "${OMNIGRAPH_GRAPH_ID:-memory}",
        "OMNIGRAPH_TOKEN": "${OMNIGRAPH_TOKEN}"
      },
      "connect_timeout": 120,
      "execute_timeout": 240,
      "disabled": false
    },
    "superpowers": {
      "command": "node",
      "args": [
        "${AGENT_SKILLS_DIR}/infra/mcp-servers/servers/superpowers/build/index.js"
      ],
      "connect_timeout": 60,
      "execute_timeout": 120,
      "disabled": false
    },
    "graphify": {
      "command": "uv",
      "args": [
        "--quiet",
        "run",
        "--with",
        "graphifyy[mcp]",
        "python",
        "-m",
        "graphify.serve",
        "graphify-out/graph.json"
      ],
      "connect_timeout": 120,
      "execute_timeout": 240,
      "disabled": false
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "YOUR_API_KEY_HERE"
      ],
      "connect_timeout": 60,
      "execute_timeout": 120,
      "disabled": false
    }
  }
}
