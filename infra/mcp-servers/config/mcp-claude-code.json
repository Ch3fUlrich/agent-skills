{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "serena-agent",
        "serena",
        "start-mcp-server",
        "--open-web-dashboard",
        "false",
        "--enable-gui-log-window",
        "false"
      ],
      "excludeTools": [
        "onboarding",
        "open_dashboard",
        "initial_instructions",
        "write_memory",
        "read_memory",
        "list_memories",
        "delete_memory",
        "rename_memory",
        "edit_memory"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "mem0": {
      "type": "sse",
      "url": "http://localhost:8001/sse",
      "excludeTools": [
        "health"
      ]
    },
    "superpowers": {
      "command": "node",
      "args": [
        "${AGENT_SKILLS_DIR}/mcp-servers/servers/superpowers/build/index.js"
      ]
    },
    "graphify": {
      "command": "uv",
      "args": [
        "--quiet",
        "run",
        "--with",
        "graphifyy[mcp]",
        "python",
        "-m",
        "graphify.serve",
        "graphify-out/graph.json"
      ]
    },
    "graphify-docker": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-v",
        "${AGENT_SKILLS_DIR}:/repo",
        "graphify-mcp:latest"
      ]
    }
  }
}
