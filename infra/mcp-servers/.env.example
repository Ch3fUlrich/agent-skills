# Self-Hosted MCP Stack Configuration
# Copy to .env and fill in your values.

# ─── Repo/code roots (used by scripts and configs; keep paths out of git) ────
# Linux/macOS example:  AGENT_SKILLS_ROOT=/home/you/code/agent-skills
# Windows example:      AGENT_SKILLS_ROOT=C:\Users\you\Documents\Code\agent-skills
AGENT_SKILLS_ROOT=
# Parent directory that holds all your repos (Serena/Graphify index root).
# Linux/macOS: CODE_ROOT=/home/you/code   |   Windows: CODE_ROOT=C:\Users\you\Documents\Code
CODE_ROOT=
# Serena home (memories/indices). Default ~/.serena — override only if relocated.
SERENA_HOME=

#
# DEFAULT stack (Omnigraph + MinIO):  omnigraph-server (:8080)  →  minio (:9000)
# FALLBACK stack (profile mem0-fallback): postgres → mem0 API → mem0-mcp → dashboard

# ═══ DEFAULT: Omnigraph + MinIO ══════════════════════════════════════════════
# ─── MinIO (S3 store backing Omnigraph) ──────────────────────────────────────
MINIO_ROOT_USER=omnigraph
MINIO_ROOT_PASSWORD=choose-a-strong-password
S3_BUCKET=omnigraph
AWS_REGION=us-east-1

# ─── Omnigraph ───────────────────────────────────────────────────────────────
# Bearer token for the implicit `default` actor. Generate a random string, e.g.
#   openssl rand -hex 32
OMNIGRAPH_TOKEN=generate-with-openssl-rand-hex-32
# Server URL the MCP bridge connects to (local by default).
OMNIGRAPH_URL=http://localhost:8080

# ═══ FALLBACK ONLY (profile mem0-fallback) ═══════════════════════════════════
# ─── DeepSeek LLM via OpenAI-compatible API ──────────────────────────────────
# No custom "deepseek" provider needed — the mem0 container uses the
# standard openai provider pointed at api.deepseek.com/v1.
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ─── Ollama Embedder (for vector embeddings) ─────────────────────────────────
# Requires Ollama running locally with bge-m3 pulled.
# Windows: host.docker.internal resolves to host from inside container
# Linux:   Use host network or host ip
OLLAMA_EMBED_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=bge-m3

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=choose-a-strong-password

# ─── Mem0 ────────────────────────────────────────────────────────────────────
MEM0_USER_ID=your-username
MEM0_TELEMETRY=false

# ─── Authentication ──────────────────────────────────────────────────────────
# ADMIN_API_KEY: any string ≥16 chars. Used as X-API-Key header for admin ops.
# Generate: powershell -Command "[Convert]::ToBase64String((1..48 | ForEach {Get-Random -Max 256}))"
ADMIN_API_KEY=your-admin-api-key-here
JWT_SECRET=generate-with-openssl-rand-base64-48

# ─── Optional ────────────────────────────────────────────────────────────────
# OLLAMA_EMBED_DIMS=1024
