# Server env — the always-on memory backend (docker-compose.server.yml).
# Load alongside .env.shared:
#   docker compose --env-file .env.shared --env-file .env.server -f docker-compose.server.yml up -d
# Copy to .env.server and fill in. Requires OMNIGRAPH_TOKEN + S3_BUCKET from .env.shared.

# ─── MinIO (S3 store backing Omnigraph) ──────────────────────────────────────
MINIO_ROOT_USER=omnigraph
MINIO_ROOT_PASSWORD=choose-a-strong-password
# Host ports for the MinIO S3 API + web console. Override if 9000/9001 are
# already used on your host (Omnigraph reaches MinIO over the internal network).
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Public URL of the MinIO console when reverse-proxied (else leave default).
MINIO_CONSOLE_URL=https://omnigraph-minio.ohje.ooguy.com

# ─── Embeddings (Ollama, openai-compatible; no cloud key) ────────────────────
# LAN IP of the Ollama host (mapped to cloud.vm via extra_hosts in the compose).
# For a fully self-contained local stack, run a local Ollama with nomic-embed-text
# pulled and set OLLAMA_HOST_IP=host-gateway (routes cloud.vm -> the Docker host).
OLLAMA_HOST_IP=192.168.178.159
OLLAMA_DUMMY_KEY=ollama

# ═══ FALLBACK ONLY (profile mem0-fallback) ═══════════════════════════════════
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
OLLAMA_EMBED_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=bge-m3
POSTGRES_PASSWORD=choose-a-strong-password
MEM0_USER_ID=your-username
MEM0_TELEMETRY=false
AUTH_DISABLED=false
