# Client env — a developer machine's MCP tools (docker-compose.client.yml).
# Load alongside .env.shared:
#   docker compose --env-file .env.shared --env-file .env.client -f docker-compose.client.yml up -d
# Copy to .env.client and fill in. Requires OMNIGRAPH_TOKEN + S3_BUCKET from .env.shared.

# ─── Paths ───────────────────────────────────────────────────────────────────
# Parent dir holding your repos — mounted into Serena at the SAME path so the
# project paths your agent sends resolve inside the container.
#   Linux/macOS: /home/you/code   |   Windows (WSL): /home/you/code
CODE_ROOT=/home/you/code
AGENT_SKILLS_ROOT=/home/you/code/agent-skills

# ─── Omnigraph memory server this client talks to ────────────────────────────
# Online: point at the central server (public URL or its LAN address).
#   e.g. https://omnigraph.ohje.ooguy.com  or  http://coding.vm:8080
# Offline (profile "offline" below): the local server at http://localhost:8080.
OMNIGRAPH_URL=https://omnigraph.ohje.ooguy.com

# ═══ OFFLINE ONLY (profile "offline") — a local Omnigraph for disconnected use ═
# A local MinIO password for the offline store (any strong value).
LOCAL_MINIO_USER=omnigraph
LOCAL_MINIO_PASSWORD=choose-a-strong-password
