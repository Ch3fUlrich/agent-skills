# Shared env — the values that CONNECT the server and its clients.
# Both roles load this file, so the token and bucket match on both sides:
#   server: docker compose --env-file .env.shared --env-file .env.server -f docker-compose.server.yml up -d
#   client: docker compose --env-file .env.shared --env-file .env.client -f docker-compose.client.yml up -d
# Copy to .env.shared and fill in. (Real .env.* files are gitignored.)

# Bearer token for the Omnigraph API. Clients authenticate with the SAME value.
#   generate: openssl rand -hex 32
OMNIGRAPH_TOKEN=generate-with-openssl-rand-hex-32

# S3 bucket / prefix name for the Omnigraph cluster (server store + offline client store).
S3_BUCKET=omnigraph
AWS_REGION=us-east-1
