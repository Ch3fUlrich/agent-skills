// Structured-memory schema for the `memory` graph.
// Typed nodes + edges (see skills/structured-memory/references/schema.md).
// Vector(768) matches the embedding provider **nomic-embed-text** (768-dim; see
// cluster/cluster.yaml). NOTE: bge-m3 is 1024-dim and is ONLY the mem0-FALLBACK
// embedder (a separate, off-by-default subsystem) — NOT this graph. Verified: the
// local stack and the production central server both store 768-dim vectors and
// search_decisions ranks against them. Populate stored vectors with
// scripts/populate-embeddings.py; with the `mock` provider stored vectors are
// empty and search falls back to graph traversal + scalar indexes.

node Project {
  slug: String
  name: String?
  path: String?
  summary: String?
  @key(slug)
}

node Decision {
  slug: String
  title: String
  rationale: String?
  status: enum(proposed, accepted, superseded, deprecated)
  date: String?
  embedding: Vector(768)? @embed("rationale")
  @key(slug)
  @index(status)
}

node Rule {
  slug: String
  statement: String
  severity: enum(must, should)
  @key(slug)
  @index(severity)
}

node Preference {
  slug: String
  statement: String
  scope: String
  @key(slug)
  @index(scope)
}

node Convention {
  slug: String
  name: String
  example: String?
  @key(slug)
}

node Component {
  slug: String
  name: String
  kind: String?
  location: String?
  @key(slug)
}

node Task {
  slug: String
  title: String
  state: String
  @key(slug)
}

edge DecidedIn: Decision -> Project
edge ConstrainsProject: Rule -> Project
edge ConstrainsComponent: Rule -> Component
edge AppliesTo: Convention -> Project
edge PartOf: Component -> Project
edge Supersedes: Decision -> Decision
