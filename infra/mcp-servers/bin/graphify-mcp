#!/bin/sh
# graphify-mcp — single, cwd-driven graphify MCP server for SERVER hosts (e.g. coding.vm)
# that run graphify via Docker instead of a per-user uv/Python toolchain.
#
# Why a wrapper: MCP client args are NOT shell-expanded, so a raw ~/.claude.json entry
# cannot inject $PWD. This script does, so a SINGLE user-scope entry
#   "graphify": { "command": "graphify-mcp" }
# serves whichever repo Claude Code launched from — the container resolves
# graphify-out/graph.json relative to /repo (the image WORKDIR).
#
# Setup on a server:
#   1. docker build -t graphify-mcp:latest infra/mcp-servers/servers/graphify-mcp
#   2. put this file on PATH (e.g. ln -s "$PWD/infra/mcp-servers/bin/graphify-mcp" /usr/local/bin/)
#   3. register the one user-scope entry above; restart Claude Code
#
# Workstations do NOT use this — they use the uv entry (skills/mcp-servers-setup/SKILL.md).
exec docker run -i --rm -v "$PWD:/repo" graphify-mcp:latest "$@"
